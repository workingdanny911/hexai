{
  "name": "@hexaijs/plugin-contracts-generator",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.7.0",
  "type": "module",
  "description": "Extract events, commands, queries, and public contracts from bounded contexts into frontend-compatible TypeScript packages",
  "license": "MIT",
  "author": "Sangwoo Hyun <wkdny.hyun@gmail.com>",
  "contributors": [
    "Seungcheol Baek <victoryiron.baek@gmail.com>",
    "Donghyun Lee <edonghyun@naver.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workingdanny911/hexai.git",
    "directory": "packages/plugin-contracts-generator"
  },
  "homepage": "https://github.com/workingdanny911/hexai#readme",
  "bugs": {
    "url": "https://github.com/workingdanny911/hexai/issues"
  },
  "keywords": [
    "hexai",
    "hexagonal",
    "clean-architecture",
    "ddd",
    "contracts",
    "code-generation",
    "typescript"
  ],
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "generate-contracts": "dist/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsgo -p tsconfig.build.json"
  },
  "dependencies": {
    "@hexaijs/contracts": "^0.3.0",
    "glob": "^10.3.0",
    "minimatch": "^9.0.0"
  },
  "peerDependencies": {
    "@hexaijs/cli": "^0.2.0",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@hexaijs/cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hexaijs/cli": "workspace:^",
    "@hexaijs/core": "workspace:^",
    "@hexaijs/tooling": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  }
}
